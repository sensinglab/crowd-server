        {
          "datasource": {
            "type": "influxdb",
            "uid": "pDZ8Hh64z"
          },
          "query": "from(bucket: \"PenaPalaceDB\")\r\n  |> range(start: 2024-11-01T00:00:00Z)\r\n  |> filter(fn: (r) => r[\"_measurement\"] == \"numdetectionstable\" )\r\n\r\n  // *** Normalize schema so old + new look identical ***\r\n  |> map(fn: (r) => ({\r\n      r with\r\n      sensor_uuid: if exists r.sensor_uuid then r.sensor_uuid else \"legacy\",\r\n      type_data:   if exists r.type_data   then r.type_data   else \"all\"\r\n  }))\r\n  // ***\r\n  // *** Apply calibration only to EntradaPrincipal devices_detected ***\r\n  |> map(fn: (r) => ({ r with _value:\r\n        if r.device == \"EntradaPrincipal\" and r._field == \"devices_detected\" then\r\n          // sensor EntradaPrincipal ≈ -30.45%\r\n          float(v: r._value) / 0.6955\r\n        else\r\n          r._value\r\n  }))\r\n  // ***\r\n  |> group(columns: [\"device\"])\r\n  |> sort(columns: [\"_time\"])\r\n  |> last(column: \"device\")\r\n  |> drop(columns:[\"_start\", \"_stop\"])\r\n  |> pivot(rowKey: [\"_time\",\"ipAddress\",\"tecnology\"], columnKey: [\"_field\"], valueColumn: \"_value\")\r\n  |> group(columns: [])\r\n  |> map(fn: (r) => ({\r\n      r with\r\n      sensor_status: if (uint(v: now()) - uint(v: r._time)) <= 600000000000 then \"Ativo\" else \"Inativo\" \r\n  }))",
          "refId": "A"
        }
      ],
      "title": "",
