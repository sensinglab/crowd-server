          "datasource": {
            "type": "influxdb",
            "uid": "pDZ8Hh64z"
          },
          "query": "t1 = from(bucket: \"PenaPalaceDB\")\n  |> range(start: 2023-08-08T00:00:00Z)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"sensorLocation\" )\n  |> last(column: \"device\")\n  |> drop(columns:[\"_start\", \"_stop\"])\n  |> pivot(rowKey: [\"_time\"], columnKey: [\"_field\"], valueColumn: \"_value\")\n  |> group()\n\n\nt2 = from(bucket: \"PenaPalaceDB\")\n  |> range(start: -10m)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"numdetectionstable\" )\n  // *** Apply calibration only to EntradaPrincipal devices_detected ***\n  |> map(fn: (r) => ({ r with _value:\n        if r.device == \"EntradaPrincipal\" and r._field == \"devices_detected\" then\n          // sensor EntradaPrincipal ≈ -30.45%\n          float(v: r._value) / 0.6955\n        else\n          r._value\n  }))\n  // ***\n  |> drop(columns:[\"_start\", \"_stop\"])\n  |> pivot(rowKey: [\"_time\"], columnKey: [\"_field\"], valueColumn: \"_value\")\n  |> last(column: \"devices_detected\")\n  |> group()\n\n\njoin( tables: {t1: t1, t2: t2}, on: [\"device\"])\n  |> group(columns: [\"device\"])\n  |> last(column: \"devices_detected\")\n  |> rename(columns: {_time_t1: \"Deployment Date\", _time_t2: \"Last Record\" }) //Renomeia colunas para melhor interpertação dos resultados (questão estética)\n  |> drop(columns:[\"_measurement_t1\", \"_measurement_t2\",\"ipaddress\", \"macAddress\",\"type_data\",\"tecnology\"])  //Elimina colunas desnecessárias \n  |> group()\n\n//union(tables: [t1,t2])",
          "refId": "A"
        }
      ],
