          },
          "query": "import \"math\"\r\n\r\nfrom(bucket: \"ICUFNDB\")\r\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\r\n  |> filter(fn: (r) => r[\"_measurement\"] == \"numdetections\")\r\n  |> filter(fn: (r) => r[\"_field\"] == \"devices_detected\")\r\n  |> filter(fn: (r) => r[\"sensor_name\"] != \"B332\")\r\n  |> filter(fn: (r) => contains(value: r[\"sensor_name\"], set: ${Sensor:json}))\r\n  |> aggregateWindow(every: 30m, fn: mean, createEmpty: false)\r\n  |> map(fn: (r) => ({r with _value: int(v: math.round(x: r._value)), _time:r._time, _field:r.sensor_name}))",
