          "query": "t1 = from(bucket: \"ICUFNDB\")\r\n  |> range(start: 2025-07-03T15:35:10Z)\r\n  |> filter(fn: (r) => r[\"_measurement\"] == \"sensorLocation\" )\r\n  |> drop(columns:[\"_start\", \"_stop\"])\r\n  |> pivot(rowKey: [\"_time\"], columnKey: [\"_field\"], valueColumn: \"_value\")\r\n  |> group()\r\n\r\n\r\nt2 = from(bucket: \"ICUFNDB\")\r\n  |> range(start: 2025-07-03T16:35:00Z)\r\n  |> filter(fn: (r) => r[\"_measurement\"] == \"numdetections\")\r\n  |> group(columns: [\"sensor_name\"])\r\n  |> last()\r\n  |> group(columns: [])\r\n  |> drop(columns: [\"_start\", \"_stop\"])\r\n\r\n\r\njoin( tables: {Locations: t1, Detections: t2}, on: [\"sensor_name\"])\r\n  |> group(columns: [\"sensor_name\"])\r\n  |> last(column: \"sensor_name\")\r\n  |> group()",
